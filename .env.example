PORT=8888
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
# 访问统计重置时间（ISO），只展示此时间之后的记录
VISIT_STATS_START_AT=2026-06-08T21:10:00.000Z
Web_Trader_UUID=your-trader-uuid

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Massive（原 Polygon.io）美股实时行情 — 从 https://massive.com/dashboard 复制
MASSIVE_API_KEY=your_massive_api_key
# 可选兼容旧变量名：POLYGON_API_KEY=your_massive_api_key
# 可选：MASSIVE_API_BASE=https://api.massive.com

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth（与前端 VITE_GOOGLE_CLIENT_ID 使用同一个 Client ID）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 本地开发默认启用；Cloudflare Workers 部署时由 wrangler.toml 覆盖
# DISABLE_SCHEDULER=true
# DISABLE_LOCAL_FS=true
