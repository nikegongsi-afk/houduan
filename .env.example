PORT=8888
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
Web_Trader_UUID=your-trader-uuid

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Polygon.io 美股实时行情
POLYGON_API_KEY=your_polygon_api_key
# 主 Key 无效时自动回退（可选）
# POLYGON_API_KEY_FALLBACK=your_backup_polygon_api_key

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth（与前端 VITE_GOOGLE_CLIENT_ID 使用同一个 Client ID）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# 本地开发默认启用；Cloudflare Workers 部署时由 wrangler.toml 覆盖
# DISABLE_SCHEDULER=true
# DISABLE_LOCAL_FS=true
